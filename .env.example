# M365 Copilot Access Token / M365 Copilot 访问令牌
# Leave empty to push via the Tampermonkey script or auto-capture.
# 留空则由油猴脚本推送或自动捕获。
M365_ACCESS_TOKEN=

# API Key (required, set your own secret key) / API 密钥（必填，设置你自己的密钥）
# Multi-tenant: this is the legacy/global admin key. Per-user API keys are
# created & bound to accounts in the /admin console. If no keys are registered
# and this is empty, all /v1/ endpoints are open without auth.
# 多租户版：这是兼容用的全局/运营方密钥。给多人用的 API Key 在 /admin 总控台
# 里创建并绑定账户。若一个 Key 都没注册且此项留空，则 /v1/ 端点无认证开放。
API_KEY=

# Admin password for the /admin console (optional, falls back to API_KEY)
# /admin 运营总控台密码（可选，未设置时回退使用 API_KEY）
ADMIN_PASSWORD=

# Timezone (default: Asia/Shanghai) / 时区（默认：Asia/Shanghai）
# Sent to Copilot so date/time answers match your locale.
# 发送给 Copilot，使日期/时间相关回答符合你的本地时区。
M365_TIME_ZONE=Asia/Shanghai

# Model alias (default: m365-copilot) / 模型别名（默认：m365-copilot）
# Custom name shown in /v1/models and echoed in responses.
# 自定义模型名，显示在 /v1/models 并在响应中回显。
M365_MODEL_ALIAS=m365-copilot

# Auto-refresh token (default: true) / 自动刷新令牌（默认：true）
AUTO_REFRESH=true

# Seconds before token expiry to trigger refresh (default: 300)
# 令牌过期前多少秒触发刷新（默认：300）
REFRESH_BEFORE_SECONDS=300

# Idle timeout in minutes - auto-refresh pauses after no /v1/ requests (default: 30)
# 空闲超时（分钟）——无 /v1/ 请求超过此时长后暂停自动刷新（默认：30）
IDLE_TIMEOUT_MINUTES=30

# Chrome CDP port (default: 9222) / Chromium CDP 端口（默认：9222）
CHROME_CDP_PORT=9222

# Log level (default: INFO) / 日志输出等级（默认：INFO）
# One of DEBUG / INFO / WARNING / ERROR / CRITICAL. High-frequency polling
# from the web admin page and /healthz are always filtered out.
# 可选 DEBUG / INFO / WARNING / ERROR / CRITICAL。Web 管理页面的高频轮询
# 及 /healthz 健康检查日志始终会被过滤。
LOG_LEVEL=INFO
