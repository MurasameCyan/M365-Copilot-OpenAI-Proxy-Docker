# M365 Copilot Access Token
M365_ACCESS_TOKEN=

# API Key (required, set your own secret key)
API_KEY=

# Timezone (default: Asia/Shanghai)
M365_TIME_ZONE=Asia/Shanghai

# Model alias (default: m365-copilot)
M365_MODEL_ALIAS=m365-copilot

# Auto-refresh token (default: true)
AUTO_REFRESH=true

# Seconds before token expiry to trigger refresh (default: 300)
REFRESH_BEFORE_SECONDS=300

# Idle timeout in minutes - auto-refresh pauses after no /v1/ requests (default: 30)
IDLE_TIMEOUT_MINUTES=30

# Chrome CDP port (default: 9222)
CHROME_CDP_PORT=9222
